{
  "license": "Unlicense",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:all": "pnpm test && pnpm test:integration",
    "test:live": "vitest run --config vitest.config.integration.ts --project live",
    "typecheck": "pnpm -r typecheck && tsc --noEmit -p tsconfig.scripts.json",
    "lint": "eslint packages/*/src scripts --ext .ts",
    "lint:fix": "eslint packages/*/src scripts --ext .ts --fix",
    "format": "prettier --write \"packages/*/src/**/*.ts\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"packages/*/src/**/*.ts\" \"scripts/**/*.ts\""
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp": "8.4.0"
    }
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "solc": "^0.8.30",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
